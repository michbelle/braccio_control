<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="r6bot_description">

  <!-- Load the YAML file -->
  <!-- <xacro:property name="yaml_file" value="$(find braccio_simulation)/urdf/config/braccio_param.yaml"/>
  <xacro:property name="robot_descr" value="${xacro.load_yaml(yaml_file)}"/> -->
  
  <!-- helper macro -->
  <xacro:include filename="$(find braccio_simulation)/model/urdf/inc/create_link.xacro"/>

  <xacro:create_link_from_box
      link_name="base_link"
      xyz_offset="0 0 0.0145"
      rpy_offset="0 0 0"
      dim_box="0.088 0.090 0.029"
  />

  <xacro:create_link_from_box
      link_name="base_up"
      xyz_offset="0 0 0"
      rpy_offset="0 0 0"
      dim_box="0.059 0.026 0.050"
  />

  <xacro:create_link_from_box
      link_name="arm_rot"
      xyz_offset="0.002 0.012 0.013"
      rpy_offset="0 0 0"
      dim_box="0.058 0.050 0.026"
  />

  <xacro:create_link_from_mesh
      link_name="arm_1_up_down_p1"
      xyz_offset="0 0 0"
      rpy_offset="0 0 -${pi2}"
      mesh_package="model/3Dparts"
      mesh_name="ModelARM-Body.stl"
  />

  <xacro:create_link_from_mesh
      link_name="arm_1_up_down_p2"
      xyz_offset="0 0 0"
      rpy_offset="${pi} 0 -${pi2}"
      mesh_package="model/3Dparts"
      mesh_name="ModelARM-Body.stl"
  />

  <xacro:create_link_from_box
      link_name="arm_2_up_down"
      xyz_offset="0.045 -0.001 0"
      rpy_offset="0 0 0"
      dim_box="0.13 0.050 0.028"
  />

  <xacro:create_link_from_mesh
      link_name="arm_3_up_down"
      xyz_offset="0 0 0"
      rpy_offset="0 0 -${pi2}"
      mesh_package="model/3Dparts"
      mesh_name="ModelARM-Body.stl"
  />

  <xacro:create_link_from_box
      link_name="box_servo_rot"
      xyz_offset="0 0 0"
      rpy_offset="0 0 0"
      dim_box="0.042 0.042 0.021"
  />

  <xacro:create_link_from_box
      link_name="rot_grasp"
      xyz_offset="0.0265 0 0"
      rpy_offset="0 0 0"
      dim_box="0.053 0.055 0.019"
  />

  <xacro:create_link_from_box
      link_name="grasp_box"
      xyz_offset="0.03 0.025 0.0165"
      rpy_offset="0 0 0"
      dim_box="0.020 0.050 0.033"
  />

  <xacro:create_link_from_box
      link_name="grasp_l"
      xyz_offset="0.029 0.005 0"
      rpy_offset="0 0 0"
      dim_box="0.058 0.010 0.020"
  />

  <xacro:create_link_from_box
      link_name="grasp_r"
      xyz_offset="0.029 -0.005 0"
      rpy_offset="0 0 0"
      dim_box="0.058 0.010 0.020"
  />



  <link name="ft_frame"/>
  <link name="tool0"/>

  <!-- base_joint fixes base_link to the environment -->
  <joint name="base_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- joints - main serial chain -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.244" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="${-pi}" upper="${pi}" velocity="2.5"/>
  </joint>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="-0.27 0 0.0" rpy="${-pi/2} -${pi/2} ${pi/2}"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="${-pi}" upper="${pi}" velocity="2.5"/>
  </joint>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0.686 0 -0.27" rpy="0 ${pi} ${pi+pi/2}"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="${-pi}" upper="${pi}" velocity="2.5"/>
  </joint>

  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0.519 0 0" rpy="0 ${pi} ${pi}"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="${-pi}" upper="${pi}" velocity="2.5"/>
  </joint>

  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0.0 0 0.188" rpy="${pi/2} ${pi} ${pi/2}"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="${-pi}" upper="${pi}" velocity="2.5"/>
  </joint>

  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0.0 0 0.246" rpy="0 ${-pi/2} 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="${-pi}" upper="${pi}" velocity="2.5"/>
  </joint>

  <joint name="joint-ft_frame" type="fixed">
    <parent link="link_6"/>
    <child link="ft_frame"/>
    <origin xyz="0 0 0.086" rpy="0 0 0"/>
  </joint>

  <joint name="joint-tool" type="fixed">
    <parent link="ft_frame"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.185" rpy="0 0 0"/>
  </joint>

</xacro:macro>

</robot>